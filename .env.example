# ── Entorno ───────────────────────────────────────────────────
# Valores: development | production
APP_ENV=production
APP_PORT=8000
APP_URL=http://localhost:8000

# ── Base de datos ─────────────────────────────────────────────
DB_HOST=db
DB_NAME=robotschool_inventory
DB_USER=rsuser
DB_PASS=cambia_esta_contraseña
DB_ROOT_PASS=cambia_esta_root_pass

# ── Sesión ────────────────────────────────────────────────────
SESSION_TIMEOUT=3600

# ── APIs externas (opcionales) ────────────────────────────────
# Anthropic — para generación de banners de cursos con IA
ANTHROPIC_API_KEY=

# Microsoft 365 OAuth — para login con cuenta corporativa
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
